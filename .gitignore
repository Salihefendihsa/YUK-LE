# =====================================================
# YÜK-LE .gitignore
# =====================================================

# ---- .NET / C# ----
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates
*.csproj.user
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
[Bb]in/
[Oo]bj/
*.dll
*.exe
*.pdb
*.mdf
*.ldf

# NuGet
**/packages/*
*.nupkg
**/[Pp]ackages/
project.lock.json
project.fragment.lock.json

# Visual Studio
.vs/
*.sln.ide/
*.rsuser
launchSettings.json

# User-specific files
*.suo
*.user
*.sln.docstates

# ---- Flutter / Dart ----
.dart_tool/
.packages
build/
*.iml
.flutter-plugins
.flutter-plugins-dependencies
.metadata

# ---- Web / Node ----
node_modules/
dist/
dist-ssr/
*.local

# ---- IDE ----
.idea/
.vscode/
*.swp
*.swo
*~

# ---- OS ----
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- Environment & Secrets ----
.env
.env.*
!.env.example
appsettings.json
appsettings.Development.json
appsettings.Production.json
secrets.json

# appsettings.example.json repo'ya GİTMELİDİR (gerçek değer içermez)
!appsettings.example.json

# ---- .NET User Secrets (dotnet user-secrets) ----
# Yerel secrets store: %APPDATA%\Microsoft\UserSecrets\<UserSecretsId>\secrets.json
# Bu dosya zaten workspace dışında olduğu için .gitignore'a eklenmesi gerekmez.
# dotnet user-secrets set "Key" "Value" ile ayarlanır.

# ---- Firebase ----
firebase-service-account.json
*-service-account.json

# ---- Database ----
*.db
*.sqlite
*.sqlite3

# ---- Docker ----
docker-compose.override.yml

# ---- Logs ----
logs/
*.log

# ---- Coverage ----
coverage/
*.lcov
TestResults/

# ---- Cursor AI IDE ----
.cursor/
.cursorrules
.cursor-tutor
.cursorignore
.cursorindexingignore
*.cursor-*
