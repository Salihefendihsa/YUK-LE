{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=yukledb;Username=postgres;Password=YOUR_PG_PASSWORD",
    "Redis": "localhost:6379,password=YOUR_REDIS_PASSWORD,abortConnect=false"
  },
  "Jwt": {
    "Key": "MIN_64_BYTE_SECRET_KEY_REPLACE_THIS_WITH_A_REAL_ONE_AT_LEAST_64_CHARS",
    "Issuer": "YukleApi",
    "Audience": "YukleUsers"
  },
  "Encryption": {
    "_comment": "v2.5.5 KVKK AES-256 CBC — 32 byte key + 16 byte IV, her ikisi de base64.",
    "_generate": "PowerShell: [Convert]::ToBase64String((New-Object byte[] 32 | ForEach-Object {...})) — veya dotnet user-secrets kullan.",
    "Key": "REPLACE_WITH_BASE64_32BYTE_AES256_KEY",
    "IV":  "REPLACE_WITH_BASE64_16BYTE_IV"
  },
  "GeminiAI": {
    "ApiKey": "YOUR_GEMINI_API_KEY",
    "Model": "gemini-1.5-flash-latest",
    "HighProModel": "gemini-1.5-pro-latest"
  },
  "Firebase": {
    "CredentialPath": "firebase-service-account.json"
  },
  "CollectAPI": {
    "ApiKey": "YOUR_COLLECTAPI_KEY"
  },
  "OSRM": {
    "BaseUrl": "https://router.project-osrm.org"
  },
  "FuelPriceWorker": {
    "UpdateHour": 0
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:5173",
      "https://localhost:3000",
      "https://your-production-domain.com"
    ]
  }
}
