{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@navlonix/shared": [
        "../../../packages/shared/src/index.ts"
      ],
      "@navlonix/shared/*": [
        "../../../packages/shared/src/*"
      ],
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
