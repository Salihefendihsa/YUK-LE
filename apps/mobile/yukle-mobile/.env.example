# --------------------------------------------------------------------------
# Navlonix Mobile — örnek geliştirme ortamı.
# Kopyala: cp .env.example .env, sonra kendi değerlerini doldur.
# .env repo'ya commit'lenmez (kök .gitignore'da `.env` ignore'dadır).
# --------------------------------------------------------------------------

# API base URL — backend nereden serve ediliyor.
#   Web (npm run web):              http://localhost:5151        (constants/api.ts otomatik)
#   Android emulator:               http://10.0.2.2:5151          (10.0.2.2 = host loopback)
#   iOS Simulator:                  http://localhost:5151         (otomatik)
#   Gerçek cihaz (telefon/tablet):  http://<bilgisayar-LAN-IP>:5151
#
# LAN IP bulma:
#   Windows:  ipconfig         → "IPv4 Address" (genelde 192.168.x.x veya 10.x.x.x)
#   macOS:    ipconfig getifaddr en0
#   Linux:    hostname -I | awk '{print $1}'
#
# API'nin 0.0.0.0:5151'de dinlediğinden emin ol (apps/api .. launchSettings.json `http` profili).
EXPO_PUBLIC_API_BASE_URL=

# Google Maps Android API key. İsteğe bağlı — sadece Android'de native harita için.
# Google Cloud Console > API Keys > "Maps SDK for Android" izinli key.
# Boş bırakılırsa Android'de harita placeholder gösterilir (mapConfig.ts).
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
