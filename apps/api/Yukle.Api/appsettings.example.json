{
  "_comment": "Bu dosya bir şablon/örnek dosyadır. Gerçek değer içermez. Gerçek değerleri dotnet user-secrets ile ayarlayın.",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=yukledb;Username=postgres;Password=YOUR_DB_PASSWORD",
    "Redis": "localhost:6379,password=YOUR_REDIS_PASSWORD,abortConnect=false"
  },

  "Jwt": {
    "Key": "YOUR_64_CHAR_SECURE_JWT_KEY_HERE_REPLACE_THIS",
    "Issuer": "YukleApi",
    "Audience": "YukleUsers"
  },

  "Encryption": {
    "Key": "YOUR_BASE64_ENCODED_32_BYTE_AES256_KEY",
    "IV": "YOUR_BASE64_ENCODED_16_BYTE_IV"
  },

  "GeminiAI": {
    "ApiKey": "YOUR_GOOGLE_GEMINI_API_KEY",
    "Model": "gemini-1.5-flash-latest",
    "HighProModel": "gemini-1.5-pro-latest"
  },

  "Firebase": {
    "CredentialPath": "firebase-service-account.json"
  },

  "Sms": {
    "Provider": "Netgsm",
    "Netgsm": {
      "UserCode": "",
      "Password": "",
      "Header": ""
    }
  },

  "Commission": {
    "DriverRate": 0.02,
    "CustomerRate": 0.02
  },
  "Settlement": {
    "StopajRate": 0.0,
    "StopajAppliesToCorporate": false
  },

  "Cancellation": {
    "AllowCustomerCancelAfterAccept": false,
    "RefundPercent": 100,
    "CancellationFee": 0,
    "AllowCancelAfterTripStart": false
  },

  "Fuel": {
    "RefreshHours": 12,
    "RequestDelayMs": 400,
    "Fallback": {
      "Diesel": 68,
      "Gasoline": 65,
      "Lpg": 31,
      "Electric": 10
    },
    "Sanity": {
      "DieselMin": 20,
      "DieselMax": 250,
      "GasolineMin": 20,
      "GasolineMax": 250,
      "LpgMin": 8,
      "LpgMax": 120,
      "MaxJumpPercent": 25
    }
  },

  "Pricing": {
    "ProfitMarginRate": 0.25,
    "VolumetricKgPerM3": 333,
    "DefaultFuelPriceTl": 68,
    "DefaultBenzinPriceTl": 65,
    "DefaultLpgPriceTl": 31,
    "ElectricityPriceTlPerKwh": 10,
    "Vehicle": {
      "TIR": {
        "FuelKind": "diesel",
        "ConsumptionPer100Km": 32,
        "TollTlPerKm": 2.0,
        "AmortizationTlPerKm": 3.5,
        "WeightSurchargePerTon": 15,
        "MinPriceBand": 0.82,
        "MaxPriceBand": 1.25
      },
      "KAMYON": {
        "FuelKind": "diesel",
        "ConsumptionPer100Km": 26,
        "TollTlPerKm": 1.5,
        "AmortizationTlPerKm": 2.5,
        "WeightSurchargePerTon": 12,
        "MinPriceBand": 0.85,
        "MaxPriceBand": 1.22
      },
      "KAMYONET": {
        "FuelKind": "diesel",
        "ConsumptionPer100Km": 13,
        "TollTlPerKm": 0.8,
        "AmortizationTlPerKm": 1.2,
        "WeightSurchargePerTon": 8,
        "MinPriceBand": 0.88,
        "MaxPriceBand": 1.18
      },
      "PANELVAN": {
        "FuelKind": "gasoline",
        "ConsumptionPer100Km": 10,
        "TollTlPerKm": 0.5,
        "AmortizationTlPerKm": 0.8,
        "WeightSurchargePerTon": 5,
        "MinPriceBand": 0.90,
        "MaxPriceBand": 1.15
      }
    }
  },

  "Delivery": {
    "_comment": "QR token her zaman zorunlu. Production'da EnforceGpsDistanceCheck=true; Development varsayılan false (demo GPS atlanır).",
    "EnforceGpsDistanceCheck": false,
    "MaxDistanceKm": 0.5
  },

  "Cors": {
    "AllowedOrigins": [
      "https://localhost:5173",
      "https://localhost:3000",
      "https://yukle.app"
    ]
  }
}
