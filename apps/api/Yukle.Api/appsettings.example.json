{
  "_comment": "Bu dosya bir şablon/örnek dosyadır. Gerçek değer içermez. Gerçek değerleri dotnet user-secrets ile ayarlayın.",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=yukledb;Username=postgres;Password=YOUR_DB_PASSWORD",
    "Redis": "localhost:6379,password=YOUR_REDIS_PASSWORD,abortConnect=false"
  },

  "Jwt": {
    "Key": "YOUR_64_CHAR_SECURE_JWT_KEY_HERE_REPLACE_THIS",
    "Issuer": "YukleApi",
    "Audience": "YukleUsers"
  },

  "Encryption": {
    "Key": "YOUR_BASE64_ENCODED_32_BYTE_AES256_KEY",
    "IV": "YOUR_BASE64_ENCODED_16_BYTE_IV"
  },

  "GeminiAI": {
    "ApiKey": "YOUR_GOOGLE_GEMINI_API_KEY",
    "Model": "gemini-1.5-flash-latest",
    "HighProModel": "gemini-1.5-pro-latest"
  },

  "Firebase": {
    "CredentialPath": "firebase-service-account.json"
  },

  "Cors": {
    "AllowedOrigins": [
      "https://localhost:5173",
      "https://localhost:3000",
      "https://yukle.app"
    ]
  }
}
